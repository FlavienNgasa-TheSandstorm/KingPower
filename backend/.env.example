# Railway injecte automatiquement ces variables
# Ne les mettez pas dans .env, elles seront dans les variables d'environnement Railway

# Variables automatiquement fournies par Railway
# MYSQLHOST
# MYSQLPORT
# MYSQLUSER
# MYSQLPASSWORD
# MYSQLDATABASE
# MYSQL_URL

# Variables personnalisées à ajouter dans Railway
JWT_SECRET=votre_secret_tres_long_et_complexe_ici
NODE_ENV=production
CLIENT_URL=https://votre-client.railway.app
ADMIN_URL=https://votre-admin.railway.app